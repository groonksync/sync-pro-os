{
  "name": "sync-pro-os",
  "private": true,
  "version": "0.0.0",
  "description": "Sovereign OS - Estación de Trabajo Profesional",
  "author": "Groonk",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "node scratch/build-catalog.js && vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && xattr -cr dist && electron-builder && rm -rf \"./Sovereign OS.app\" && cp -R \"release/mac-arm64/Sovereign OS.app\" \"./\" && cp \"release/Sovereign OS-0.0.0-arm64.dmg\" \"./Sovereign OS (Instalador).dmg\""
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@google/generative-ai": "^0.24.1",
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/icons": "^5.8.0",
    "@lobehub/ui": "^5.12.0",
    "@react-oauth/google": "^0.13.5",
    "@supabase/supabase-js": "^2.39.3",
    "antd": "^6.3.7",
    "axios": "^1.15.2",
    "crypto-js": "^4.2.0",
    "gapi-script": "^1.2.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.312.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "vite": "^5.0.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.sovereign.os",
    "productName": "Sovereign OS",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "identity": null
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ]
  }
}
